# ============================================
# 燃冬AI - 环境变量配置模板
# 复制本文件为 .env.local 并填写实际值
# cp .env.example .env.local
# ============================================

# ---------- AI生图 - DMXAPI ----------
# 单个Key（兼容模式）
COZE_API_KEY=sk-xxxx

# 多Key轮转（逗号分隔，支持负载均衡和自适应扩容）
# 5个Key → 70并发/420RPM，8个Key → 100并发/600RPM
DMXAPI_API_KEYS=sk-xxxx1,sk-xxxx2,sk-xxxx3

# ---------- AI视频 - 火山方舟 ----------
# 方舟API Key（逗号分隔多个Key，自动负载均衡）
ARK_API_KEYS=ark-xxxx1,ark-xxxx2

# ---------- Supabase 数据库 ----------
# 平台部署时自动注入，本地开发需手动配置
# 在 Supabase 项目 Settings → API 中获取
COZE_SUPABASE_URL=https://xxxx.supabase.co
COZE_SUPABASE_ANON_KEY=eyJhbGciOi...
COZE_SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- 支付宝当面付 ----------
# 在支付宝开放平台获取：https://open.alipay.com
ALIPAY_APP_ID=你的应用ID
ALIPAY_PRIVATE_KEY=你的RSA2应用私钥
ALIPAY_ALIPAY_PUBLIC_KEY=支付宝RSA2公钥（用于验签）
# 网关地址：沙箱用下方地址，正式环境改为 https://openapi.alipay.com/gateway.do
ALIPAY_GATEWAY=https://openapi-sandbox.dl.alipaydev.com/gateway.do
